{
  "schemaVersion": 1,
  "id": "fungus",
  "version": "${version}",
  "name": "Fungus",
  "description": "Client-side QoL mod with multiple toggleable modules (viewmodel tweaks, potion icon hider, scoreboard hider) and an in-game GUI.",
  "authors": [
    "ryn"
  ],
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "main": [
      "io.github.ryn.fungus.Fungus"
    ],
    "client": [
      "io.github.ryn.fungus.FungusClient"
    ]
  },
  "mixins": [
    "fungus.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.0",
    "minecraft": "1.21.11",
    "java": ">=21",
    "fabric-api": "*"
  }
}
